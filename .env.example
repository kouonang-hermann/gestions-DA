# ========================================
# NOTIFICATIONS EMAIL - ENVOI
# ========================================
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application
EMAIL_FROM=noreply@gestion-materiel.com

# Ou configuration SMTP personnalisée
# SMTP_HOST=smtp.votre-serveur.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=votre-utilisateur
# SMTP_PASSWORD=votre-mot-de-passe

# ========================================
# RÉCEPTION EMAIL - IMAP
# ========================================
# Configuration IMAP pour recevoir les réponses aux emails
# Par défaut, utilise les mêmes credentials que EMAIL_USER/EMAIL_PASSWORD
# Vous pouvez spécifier des credentials différents si nécessaire

# Gmail (par défaut)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=votre-email@gmail.com
IMAP_PASSWORD=votre-mot-de-passe-application

# Ou IMAP personnalisé
# IMAP_HOST=imap.votre-serveur.com
# IMAP_PORT=993
# IMAP_USER=votre-utilisateur
# IMAP_PASSWORD=votre-mot-de-passe

# Token de sécurité pour webhooks (optionnel)
# EMAIL_WEBHOOK_TOKEN=votre-token-secret-unique

# ========================================
# NOTIFICATIONS WHATSAPP (TWILIO)
# ========================================
# Créez un compte sur https://www.twilio.com
# Récupérez vos credentials depuis la console Twilio

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Numéro WhatsApp Twilio
# Sandbox (tests) : whatsapp:+14155238886
# Production : votre numéro WhatsApp Business
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ========================================
# ACTIVATION DES CANAUX DE NOTIFICATION
# ========================================
# Email activé par défaut, WhatsApp désactivé par défaut
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WHATSAPP_NOTIFICATIONS=true

# ========================================
# APPLICATION
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
